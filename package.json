{
	"name": "@commoncurriculum/ts-surgeon",
	"version": "0.0.0-development",
	"_version_note": "Pinned on purpose. Git tag (vX.Y.Z) is the single source of truth — release.yml bakes the tag value into this field and into src/version.ts before `pnpm publish`. Do NOT bump by hand. See .claude/skills/release/SKILL.md.",
	"description": "AST-accurate TypeScript/JavaScript refactoring CLI powered by ts-morph",
	"main": "dist/index.js",
	"bin": {
		"ts-surgeon": "dist/index.js"
	},
	"files": ["dist", "package.json", "README.md"],
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/commoncurriculum/ts-surgeon.git"
	},
	"packageManager": "pnpm@11.1.2",
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "pnpm run clean && tsc && shx chmod +x dist/index.js",
		"prepare": "shx rm -rf dist && tsc && shx chmod +x dist/index.js",
		"prepublishOnly": "pnpm run build",
		"test": "vitest run --pool threads --poolOptions.threads.singleThread",
		"test:e2e": "vitest run --config vitest.e2e.config.ts",
		"test:e2e:agent": "TS_SURGEON_E2E_AGENT=1 vitest run --config vitest.e2e.config.ts e2e/agent-hook.e2e.test.ts",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"check-types": "tsc --noEmit",
		"lint": "biome lint ./",
		"lint:fix": "biome lint --write ./",
		"format": "biome check --write ./"
	},
	"keywords": ["cli", "ts-morph", "refactoring", "typescript"],
	"author": "Common Curriculum",
	"contributors": ["SiroSuzume (original author of mcp-ts-morph)"],
	"license": "MIT",
	"engines": {
		"node": ">=22"
	},
	"volta": {
		"node": "22.14.0"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@types/node": "22.14.0",
		"@vitest/coverage-v8": "3.1.2",
		"lefthook": "1.11.11",
		"pino-pretty": "13.0.0",
		"shx": "0.4.0",
		"tsx": "4.19.3",
		"vitest": "3.1.2"
	},
	"dependencies": {
		"pino": "9.6.0",
		"ts-morph": "25.0.1",
		"typescript": "5.8.3",
		"zod": "3.24.3",
		"zod-to-json-schema": "3.24.5"
	}
}
